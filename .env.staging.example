# =============================================================================
# Zenno AI Suite — Staging Environment Template
# -----------------------------------------------------------------------------
# NUNCA commitar valores reais. Este arquivo contém APENAS placeholders.
# Copie para `.env.staging` e preencha via cofre externo (Doppler / Vault /
# 1Password / Secrets Manager). Nunca versionar `.env.staging`.
# =============================================================================

# -------- Application --------
APP_ENV=staging
APP_VERSION=staging-YYYYMMDD-HHMM
SERVICE_NAME=zenno-api
NODE_ENV=production
PORT=3000

# -------- Supabase (client + server) --------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
VITE_SUPABASE_PROJECT_ID=<supabase-project-ref>
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# -------- Postgres (self-hosted / worker) --------
POSTGRES_USER=<postgres-user>
POSTGRES_PASSWORD=<postgres-password>
POSTGRES_DB=<postgres-db>
POSTGRES_PORT=5432
DATABASE_URL=postgres://<user>:<password>@postgres:5432/<db>

# -------- Redis (fila BullMQ, cache) --------
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# -------- Tracking --------
TRACKING_ALLOWED_ORIGINS=https://staging.zenno.example
TRACKING_RATE_LIMIT_PER_MIN=120
TRACKING_HMAC_SECRET=<tracking-hmac-secret>

# -------- OAuth Meta (Ads / CAPI) --------
META_APP_ID=<meta-app-id>
META_APP_SECRET=<meta-app-secret>
META_OAUTH_REDIRECT_URI=https://staging.zenno.example/api/public/meta/oauth/callback
META_CAPI_ACCESS_TOKEN=<meta-capi-token>

# -------- OAuth Google (Ads / Offline Conversions) --------
GOOGLE_ADS_CLIENT_ID=<google-client-id>
GOOGLE_ADS_CLIENT_SECRET=<google-client-secret>
GOOGLE_ADS_DEVELOPER_TOKEN=<google-developer-token>
GOOGLE_OAUTH_REDIRECT_URI=https://staging.zenno.example/api/public/google-ads/oauth/callback

# -------- WhatsApp (Uazapi) --------
WHATSAPP_PROVIDER=uazapi
UAZAPI_BASE_URL=https://api.uazapi.example
UAZAPI_API_KEY=<uazapi-api-key>
UAZAPI_WEBHOOK_SECRET=<uazapi-webhook-secret>

# -------- Payments --------
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
MERCADOPAGO_ACCESS_TOKEN=<mercadopago-access-token>
MERCADOPAGO_WEBHOOK_SECRET=<mercadopago-webhook-secret>
ASAAS_API_KEY=<asaas-api-key>

# -------- AI (Lovable Gateway / fallback) --------
AI_PROVIDER=lovable
LOVABLE_API_KEY=<lovable-api-key>
OPENAI_API_KEY=<openai-api-key-optional>

# -------- Logging --------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_REDACT_KEYS=authorization,token,password,api_key,secret,webhook_secret,service_role_key

# -------- Observability --------
SENTRY_DSN=<sentry-dsn>
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
DATADOG_API_KEY=<datadog-api-key-optional>
OTEL_EXPORTER_OTLP_ENDPOINT=<otel-endpoint-optional>

# -------- Docker --------
APP_PORT=3000
COMPOSE_PROJECT_NAME=zenno-staging

# -------- CI --------
ADS_PROVIDER=meta
CI_CACHE_KEY=<hash-of-bun-lock>
